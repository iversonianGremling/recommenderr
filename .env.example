LISTEN_HOST=0.0.0.0
LISTEN_PORT=9001
DB_PATH=/opt/recommenderr/data/recommenderr.db

# Shared secret expected from ytvideo/ytmusic in Authorization: Bearer <token>.
RECOMMENDERR_TOKEN=change-me

# Optional admin UI token (defaults to bound on localhost if unset).
ADMIN_TOKEN=

# External Invidious instance.
INVIDIOUS_URL=http://192.168.1.173:3000

# Music API keys (optional; clients gracefully skip if unset).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_KEY=
DISCOGS_TOKEN=

YTDLP_CACHE_TTL=900
DISABLE_WORKERS=0
